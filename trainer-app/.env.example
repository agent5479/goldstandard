# Copy to .env.local and fill in values from Firebase Console → Project settings → Your apps.
# Never commit .env.local.

# Firebase web app (project: gsdt-trainer-private)
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=gsdt-trainer-private.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://gsdt-trainer-private-default-rtdb.firebaseio.com/
VITE_FIREBASE_PROJECT_ID=gsdt-trainer-private
VITE_FIREBASE_STORAGE_BUCKET=gsdt-trainer-private.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Offline dev fallback only — leave blank in production builds
VITE_ADMIN_USERNAME=warwick
VITE_ADMIN_PASSWORD=

VITE_DEFAULT_TENANT_ID=gsdt

# Booking import (optional) — key must match Apps Script Script Property TRAINER_IMPORT_KEY
VITE_BOOKING_API_URL=https://script.google.com/macros/s/AKfycbyp6j016DNRJu_v5hQVdyju7zTrEHBKP8VtwixSDgsp1nVhiiq8QkMmu_ozHD0Bj8bJWg/exec
VITE_BOOKING_IMPORT_KEY=your-import-key-here
